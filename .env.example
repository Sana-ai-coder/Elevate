# Backend
FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET=change-me
ADMIN_TOKEN=dev-admin-token
DATABASE_URL=sqlite:///elevate_dev.db
# Preferred for Render + Supabase (often avoids IPv6 connectivity issues)
# SUPABASE_POOLER_CONNECTION_STRING=postgresql://postgres.<project-ref>:<password>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
# Optional Supabase helpers when DATABASE_URL is misconfigured as project URL
# SUPABASE_DIRECT_CONNECTION_STRING=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# SUPABASE_DB_PASSWORD=your_supabase_db_password
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Topic AI service (TinyLlama/FastAPI)
AI_TOPIC_SERVICE_URL=http://127.0.0.1:7860
# For HF Spaces use the live host, not the Hugging Face page URL:
# AI_TOPIC_SERVICE_URL=https://<owner>-<space>.hf.space
AI_TOPIC_LLM_ONLY_DEFAULT=false
AI_TOPIC_ALLOW_LOCAL_FALLBACK_DEFAULT=true
AI_TOPIC_SERVICE_TIMEOUT_SECONDS=45
# Optional auth for private/protected AI endpoint (e.g., Hugging Face endpoint/Space)
# AI_TOPIC_SERVICE_TOKEN=your_token_here
AI_TOPIC_SERVICE_AUTH_SCHEME=Bearer

# Optional shared Hugging Face token (backend falls back to this if AI_TOPIC_SERVICE_TOKEN is not set)
# HF_TOKEN=your_hf_token

# Local startup tuning (used by start.bat/startup_healthcheck.py)
ELEVATE_FAST_STARTUP=1
ELEVATE_BUILD_INTERACTION_DATASET=0
ELEVATE_BUILD_BKT_MODEL=0
ELEVATE_BUILD_DKT_MODEL=0
ELEVATE_BUILD_EMOTION_MODEL=0
ELEVATE_BUILD_AT_RISK_MODEL=0

# Optional legacy provider settings for non-topic routes
# AI_PROVIDER=openai
# AI_API_KEY=your-openai-key
# AI_MODEL=gpt-4o-mini
# AI_API_BASE=https://api.openai.com/v1

# Frontend
API_BASE_URL=http://localhost:5000/api
FRONTEND_ORIGIN=http://localhost:8000

# Render static frontend build variable
# FRONTEND_API_BASE_URL=https://your-backend.onrender.com/api
