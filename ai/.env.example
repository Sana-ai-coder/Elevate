LLM_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Optional LoRA adapter path
# LORA_ADAPTER_PATH=adapters/tinyllama_mcq_lora

# Strict behavior
LLM_ONLY_MODE=true
ENABLE_TEMPLATE_FALLBACK=false
LLM_MAX_ATTEMPTS=18
LLM_TOTAL_TIME_BUDGET_SECONDS=120

# Generation controls
MAX_PROMPT_TOKENS=1200
MAX_NEW_TOKENS=420
TEMPERATURE=0.2
TOP_P=0.92
LLM_GENERATE_MAX_TIME_SECONDS=18

# Hybrid/fallback tuning
LLM_BATCH_SIZE=4
MAX_LLM_QUESTIONS_PER_REQUEST=8
FACT_SENTENCE_MIN_CHARS=55
CPU_LLM_MAX_TARGET=2
CPU_LLM_MAX_ATTEMPTS=2
CPU_LLM_MAX_NEW_TOKENS=96
CPU_LLM_DISABLE_THRESHOLD=8

# Context retrieval
WEB_CONTEXT_MAX_CHARS=3200
REQUEST_TIMEOUT_SECONDS=4

# Optional HF token
# HF_TOKEN=your_hf_token
# HUGGING_FACE_HUB_TOKEN=your_hf_token
# HUGGINGFACEHUB_API_TOKEN=your_hf_token
