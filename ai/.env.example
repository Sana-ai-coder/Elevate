LLM_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Cache and startup controls
# MODELS_CACHE_DIR=/data/elevate_models_cache
PRELOAD_MODEL_ON_STARTUP=true

# Optional LoRA adapter path
# LORA_ADAPTER_PATH=adapters/tinyllama_mcq_lora

# Strict behavior
LLM_ONLY_MODE=true
ENABLE_TEMPLATE_FALLBACK=false
LLM_MAX_ATTEMPTS=8
LLM_TOTAL_TIME_BUDGET_SECONDS=28

# Generation controls
MAX_PROMPT_TOKENS=1200
MAX_NEW_TOKENS=280
TEMPERATURE=0.2
TOP_P=0.92
LLM_GENERATE_MAX_TIME_SECONDS=8

# Hybrid/fallback tuning
LLM_BATCH_SIZE=3
MAX_LLM_QUESTIONS_PER_REQUEST=6
FACT_SENTENCE_MIN_CHARS=55
CPU_LLM_MAX_TARGET=2
CPU_LLM_MAX_ATTEMPTS=3
CPU_LLM_MAX_NEW_TOKENS=140
CPU_LLM_DISABLE_THRESHOLD=8

# Context retrieval
WEB_CONTEXT_MAX_CHARS=3200
REQUEST_TIMEOUT_SECONDS=4

# Optional HF token
# HF_TOKEN=your_hf_token
# HUGGING_FACE_HUB_TOKEN=your_hf_token
# HUGGINGFACEHUB_API_TOKEN=your_hf_token

# Optional API auth for this service (when exposed publicly)
# AI_TOPIC_SERVICE_TOKEN=your_shared_backend_to_ai_token
# AI_TOPIC_SERVICE_AUTH_SCHEME=Bearer
